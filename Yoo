local function getBatTargetParts(targetChar, myPos)
    local targetHead = targetChar:FindFirstChild("Head")
    local targetHRP  = targetChar:FindFirstChild("HumanoidRootPart")
    local targetUpper = targetChar:FindFirstChild("UpperTorso")
    local targetLower = targetChar:FindFirstChild("LowerTorso")
    if not targetHead or not targetHRP then return targetHRP, targetHRP end
    local headY = targetHead.Position.Y
    local myY   = myPos.Y
    if headY > myY + 3 then
        return targetHead, targetHead
    elseif myY > headY + 3 then
        return targetLower or targetHRP, targetLower or targetHRP
    else
        return targetUpper or targetHRP, targetUpper or targetHRP
    end
end

local function startBatAimbot()
    if aimbotConnection then return end
    batAimbotEnabled = true
    local equippedThisRun = false
    aimbotConnection = RunService.Heartbeat:Connect(function()
        if not batAimbotEnabled then return end
        local c = lp.Character; if not c then return end
        local hum = c:FindFirstChildOfClass("Humanoid"); if not hum then return end
        local root = c:FindFirstChild("HumanoidRootPart"); if not root then return end
        if isRagdollState(hum) then return end
        if not equippedThisRun then
            equippedThisRun = true
            if not c:FindFirstChildOfClass("Tool") then
                local bp = lp:FindFirstChildOfClass("Backpack")
                local bpBat = bp and bp:FindFirstChild("Bat")
                if bpBat then pcall(function() hum:EquipTool(bpBat) end) end
            end
        end
        local targetHRP = getBatAimbotTarget()
        if not targetHRP then
            hum.AutoRotate = true
            root.AssemblyAngularVelocity = Vector3.zero
            return
        end
        local targetChar = targetHRP.Parent
        local targetHum  = targetChar and targetChar:FindFirstChildOfClass("Humanoid")
        if not targetHum or targetHum.Health <= 0 then return end

        local myPos = root.Position
        local targetPart, _ = getBatTargetParts(targetChar, myPos)
        if not targetPart then return end

        local spd = getFloatSpeed()
        local currentVel = targetHRP.AssemblyLinearVelocity

        local facingOffset = targetHRP.CFrame.LookVector * AIM_FACING_PREDICTION
        local predictedPos = targetPart.Position + facingOffset + (currentVel * AIM_BASE_PREDICTION)

        local predOffset = predictedPos - targetPart.Position
        if predOffset.Magnitude > AIM_PREDICTION_RADIUS then
            predictedPos = targetPart.Position + predOffset.Unit * AIM_PREDICTION_RADIUS
        end

        local flatDir = Vector3.new(predictedPos.X - myPos.X, 0, predictedPos.Z - myPos.Z)
        local standPos = predictedPos - (flatDir.Unit * AIM_BEHIND_DISTANCE) + Vector3.new(0, AUTO_BAT_HEIGHT, 0)

        local headPos = targetChar:FindFirstChild("Head") and targetChar:FindFirstChild("Head").Position or targetPart.Position
        local headY = headPos.Y
        local targetVelY = currentVel.Y
        local predictedY = headY + (targetVelY * AIM_BASE_PREDICTION)
        if math.abs(predictedY - headY) > 8 then
            predictedY = headY + (predictedY - headY) / math.abs(predictedY - headY) * 8
        end
        local yVel = math.clamp((headY - myPos.Y) * 20, -120, 120)

        local moveDir = standPos - myPos
        local hDir = Vector3.new(moveDir.X, 0, moveDir.Z)
        local hVel = hDir.Magnitude > 0.1 and hDir.Unit * spd or Vector3.zero
        local vVel = Vector3.new(0, yVel, 0)
        root.AssemblyLinearVelocity = hVel + vVel

        hum.AutoRotate = false
        if hDir.Magnitude > 0.1 then hum:Move(hDir.Unit, false) end

        local dist = (root.Position - targetHRP.Position).Magnitude
        if dist <= MEDUSA_AIMBOT_RADIUS + 2 then tryHitBatAimbot() end

        local bat = c:FindFirstChild("Bat")
        if bat and bat:IsA("Tool") then pcall(function() bat:Activate() end) end
    end)
end

local function stopBatAimbot()
    batAimbotEnabled = false
