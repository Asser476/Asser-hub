local AntiRagdollEnabled = false
local ragConns = {}

local function enableControlsSafe()
    pcall(function()
        local m = lp:WaitForChild("PlayerScripts"):WaitForChild("PlayerModule")
        require(m):GetControls():Enable()
    end)
end

local function cleanupRagdoll(char, humanoid, animator)
    local desc = char:GetDescendants()
    for i = 1, #desc do
        local obj = desc[i]
        if obj:IsA("Motor6D") then obj.Enabled = true end
    end
    for i = 1, #desc do
        local obj = desc[i]
        if obj:IsA("BallSocketConstraint") or obj:IsA("NoCollisionConstraint") or obj:IsA("HingeConstraint")
            or (obj:IsA("Attachment") and (obj.Name == "RagdollAttachment" or obj.Name == "A" or obj.Name == "B"))
            or obj:IsA("BodyVelocity") or obj:IsA("BodyPosition") or obj:IsA("BodyGyro") then
            pcall(function() obj:Destroy() end)
        end
    end
    if animator then
        local tracks = animator:GetPlayingAnimationTracks()
        for i = 1, #tracks do
            local track = tracks[i]
            local n = track.Animation and track.Animation.Name:lower() or ""
            if n:find("rag") or n:find("fall") or n:find("hurt") or n:find("down") then track:Stop(0) end
        end
    end
    pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.GettingUp) end)
    task.defer(function() pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.Running) end) end)
    local camera = Workspace.CurrentCamera; if camera then camera.CameraSubject = humanoid end
end

local function isKnockbackState(hum)
    local s = hum:GetState()
    return s == Enum.HumanoidStateType.Physics or s == Enum.HumanoidStateType.Ragdoll
        or s == Enum.HumanoidStateType.FallingDown or s == Enum.HumanoidStateType.GettingUp
end

local function cleanAntiRagdoll()
    for i = 1, #ragConns do
        if ragConns[i] then ragConns[i]:Disconnect() end
    end
    ragConns = {}
end

local function runAntiRagdoll()
    cleanAntiRagdoll()
    local char = lp.Character; if not char then return end
    local humanoid = char:WaitForChild("Humanoid")
    local animator = humanoid:WaitForChild("Animator")
    pcall(function() humanoid:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false) end)
    pcall(function() humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false) end)
    table.insert(ragConns, RunService.Heartbeat:Connect(function()
        if not AntiRagdollEnabled then return end
        local c = lp.Character; if not c then return end
        local root = c:FindFirstChild("HumanoidRootPart")
        local hum2 = c:FindFirstChildOfClass("Humanoid")
        if hum2 then
            local s = hum2:GetState()
            if s == Enum.HumanoidStateType.Physics or s == Enum.HumanoidStateType.Ragdoll or s == Enum.HumanoidStateType.FallingDown then
                hum2:ChangeState(Enum.HumanoidStateType.Running)
                workspace.CurrentCamera.CameraSubject = hum2
                enableControlsSafe()
                if root then root.Velocity = Vector3.zero; root.RotVelocity = Vector3.zero end
            end
        end
        local cDesc = c:GetDescendants()
        for i = 1, #cDesc do
            local obj = cDesc[i]
            if obj:IsA("Motor6D") and not obj.Enabled then obj.Enabled = true end
        end
    end))
    table.insert(ragConns, humanoid.StateChanged:Connect(function(_, newState)
        if not AntiRagdollEnabled then return end
        if newState == Enum.HumanoidStateType.Physics or newState == Enum.HumanoidStateType.Ragdoll or newState == Enum.HumanoidStateType.FallingDown then
            cleanupRagdoll(char, humanoid, animator); enableControlsSafe()
        end
    end))
    table.insert(ragConns, char.DescendantAdded:Connect(function(obj)
        if not AntiRagdollEnabled then return end
        if obj:IsA("BallSocketConstraint") or obj:IsA("HingeConstraint") or obj:IsA("NoCollisionConstraint") then
            task.defer(function()
                if obj and obj.Parent then pcall(function() obj:Destroy() end) end
                if isKnockbackState(humanoid) then cleanupRagdoll(char, humanoid, animator); enableControlsSafe() end
            end)
        end
    end))
    enableControlsSafe()
    if isKnockbackState(humanoid) then cleanupRagdoll(char, humanoid, animator) end
end

local function toggleAntiRagdoll(state)
    AntiRagdollEnabled = state
    if state then runAntiRagdoll() else cleanAntiRagdoll() end
end

lp.CharacterAdded:Connect(function() task.wait(0.5); if AntiRagdollEnabled then runAntiRagdoll() end end)

