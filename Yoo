    local function getDefaultSemiWP() return sideShort=="left" and leftSemiWaypoints or rightSemiWaypoints end
    local function isSemiMode() return (sideShort=="left" and leftPlayType=="semi") or (sideShort=="right" and rightPlayType=="semi") end

    local function vec3ToStr(v) return string.format("Vector3.new(%.2f, %.2f, %.2f)",v.X,v.Y,v.Z) end
    local function copyWaypointsToClipboard(wpList)
        local lines = {}
        for i=1,#wpList do table.insert(lines,vec3ToStr(wpList[i])) end
        pcall(function() setclipboard(table.concat(lines,"\n")) end)
    end

    local fullBtns = {}
