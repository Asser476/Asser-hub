    s["AutoAfterDropEnabled"]=autoAfterDropEnabled; s["AutoAfterDropDelay"]=autoAfterDropDelay; s["AutoAfterDropChoice"]=autoAfterDropChoice
    s["AntiBat"]=antiBatEnabled; s["SlowFall"]=slowFallEnabled; s["XrayEnabled"]=xrayEnabled; s["SquareButtonMode"]=squareButtonMode
    s["AutoTpWhenCarrying"]=autoTpDownWhenCarryingEnabled
    -- [NEW] Save reAutoPlay settings
    s["ReAutoPlayEnabled"]=reAutoPlayEnabled; s["ReAutoPlayDelay"]=reAutoPlayDelay
    s["NormalSpeedIda"]=tonumber(speedGoingBox.Text) or NORMAL_SPEED_IDA; s["NormalSpeedVolta"]=tonumber(speedVoltaBox.Text) or NORMAL_SPEED_VOLTA
