    s["LagSpeedIda"]=tonumber(lagSpeedGoingBox.Text) or LAG_SPEED_IDA; s["LagSpeedVolta"]=tonumber(lagSpeedVoltaBox.Text) or LAG_SPEED_VOLTA
    s["LagFloatSpeed"]=tonumber(lagLockInSpeedBox.Text) or LAG_FLOAT_SPEED; s["LagMedusaSpeed"]=tonumber(lagMedusaAimSpeedBox.Text) or LAG_MEDUSA_SPEED
    s["BypassSpeedIda"]=tonumber(bypassGoingBox.Text) or BYPASS_SPEED_IDA; s["BypassSpeedVolta"]=tonumber(bypassVoltaBox.Text) or BYPASS_SPEED_VOLTA
    s["BypassFloatSpeed"]=tonumber(bypassAimbotBox.Text) or BYPASS_FLOAT_SPEED; s["BypassMedusaSpeed"]=tonumber(bypassMedusaAimBox.Text) or BYPASS_MEDUSA_SPEED
    s["BypassLagAmount"]=bypassLagAmount; s["StealRadius"]=STEAL_R; s["StealDuration"]=math.max(STEAL_DURATION,1.3)
    s["AutoPlayCD"]=autoPlayCD; s["AutoTpYLimit"]=autoTpYLimit; s["SpeedBoost"]=speedBoostEnabled
    s["FOV"]=currentFOV; s["FOVEnabled"]=fovEnabled; s["MedusaRange"]=MEDUSA_RANGE
    s["ShowMySpeed"]=showSpeedEnabled; s["ShowOthersSpeed"]=showPlayersSpeedEnabled
    s["MobileButtonsDraggable"]=mobileButtonsDraggable
    s["LeftCustomWaypoints"]=leftCustomWaypoints; s["RightCustomWaypoints"]=rightCustomWaypoints
    s["LeftCustomSemiWaypoints"]=leftCustomSemiWaypoints; s["RightCustomSemiWaypoints"]=rightCustomSemiWaypoints
    for k,kc in pairs(KB) do s["KB_"..k]=kbName(kc) end
    local bp={}
    for name,btn in pairs(mobileBtnRegistry) do
        bp[name]={XScale=btn.Position.X.Scale,XOffset=btn.Position.X.Offset,YScale=btn.Position.Y.Scale,YOffset=btn.Position.Y.Offset}
