    trackBg.ZIndex = 23; Instance.new("UICorner", trackBg).CornerRadius = UDim.new(1, 0)
    local startPct = (currentFOV-30)/(120-30)
    local trackFill = Instance.new("Frame", trackBg)
    trackFill.Size = UDim2.new(startPct, 0, 1, 0); trackFill.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
    trackFill.BorderSizePixel = 0; trackFill.ZIndex = 24
    Instance.new("UICorner", trackFill).CornerRadius = UDim.new(1, 0)
