    knob.Size = UDim2.new(0, 10, 0, 10); knob.Position = UDim2.new(startPct, -5, 0.5, -5)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255); knob.BorderSizePixel = 0
    knob.ZIndex = 25; Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
    local hitbox = Instance.new("TextButton", trackBg)
    hitbox.Size = UDim2.new(1, 0, 4, 0); hitbox.Position = UDim2.new(0, 0, -1.5, 0)
    hitbox.BackgroundTransparency = 1; hitbox.Text = ""; hitbox.ZIndex = 26
    local fovDragging = false
    local function updateFovSlider(input)
        local relX = math.clamp((input.Position.X - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X, 0, 1)
        trackFill.Size = UDim2.new(relX, 0, 1, 0); knob.Position = UDim2.new(relX, -5, 0.5, -5)
        local newFov = math.floor(30+(120-30)*relX); lbl.Text = "FOV: "..newFov; applyFOV(newFov)
    end
    uiCallbacks["FOVSlider"] = function(fovVal)
        local relX = math.clamp((fovVal-30)/(120-30), 0, 1)
        trackFill.Size = UDim2.new(relX, 0, 1, 0); knob.Position = UDim2.new(relX, -5, 0.5, -5)
        lbl.Text = "FOV: "..fovVal
    end
    hitbox.InputBegan:Connect(function(input)
        if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then
            fovDragging = true; updateFovSlider(input)
        end
    end)
    UIS.InputEnded:Connect(function(input)
        if (input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch) and fovDragging then
            fovDragging = false; triggerAutoSave()
        end
    end)
    UIS.InputChanged:Connect(function(input)
        if fovDragging and (input.UserInputType==Enum.UserInputType.MouseMovement or input.UserInputType==Enum.UserInputType.Touch) then
            updateFovSlider(input)
        end
    end)
end

