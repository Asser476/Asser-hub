    copyDefaultSemiBtn.Size=UDim2.new(1,0,0,18); copyDefaultSemiBtn.BackgroundColor3=Color3.fromRGB(0,60,140); copyDefaultSemiBtn.BorderSizePixel=0
    copyDefaultSemiBtn.Text="Copy Default Waypoints"; copyDefaultSemiBtn.TextColor3=Color3.new(1,1,1)
    copyDefaultSemiBtn.Font=Enum.Font.GothamBold; copyDefaultSemiBtn.TextSize=7; copyDefaultSemiBtn.TextScaled=false; copyDefaultSemiBtn.ZIndex=22; copyDefaultSemiBtn.LayoutOrder=12.1
    Instance.new("UICorner",copyDefaultSemiBtn).CornerRadius=UDim.new(0,3)
    copyDefaultSemiBtn.MouseButton1Click:Connect(function()
        copyWaypointsToClipboard(getDefaultSemiWP()); copyDefaultSemiBtn.Text="Copied!"
        task.delay(2,function() if copyDefaultSemiBtn and copyDefaultSemiBtn.Parent then copyDefaultSemiBtn.Text="Copy Default Waypoints" end end)
    end)

    local copyCustomSemiBtn=Instance.new("TextButton",expandFrame)
    copyCustomSemiBtn.Size=UDim2.new(1,0,0,18); copyCustomSemiBtn.BackgroundColor3=Color3.fromRGB(0,60,140); copyCustomSemiBtn.BorderSizePixel=0
    copyCustomSemiBtn.Text="Copy Custom Waypoints"; copyCustomSemiBtn.TextColor3=Color3.new(1,1,1)
    copyCustomSemiBtn.Font=Enum.Font.GothamBold; copyCustomSemiBtn.TextSize=7; copyCustomSemiBtn.TextScaled=false; copyCustomSemiBtn.ZIndex=22; copyCustomSemiBtn.LayoutOrder=12.2
    Instance.new("UICorner",copyCustomSemiBtn).CornerRadius=UDim.new(0,3)
    copyCustomSemiBtn.MouseButton1Click:Connect(function()
        local custom=getCustomSemiWP(); local count=0
        for i=1,2 do if custom[i] then count=i end end
        if count>0 then local r={} for i=1,count do if custom[i] then table.insert(r,custom[i]) end end copyWaypointsToClipboard(r)
