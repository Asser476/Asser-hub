            task.delay(2, function()
                if copyCustomFullBtn and copyCustomFullBtn.Parent then
                    copyCustomFullBtn.BackgroundColor3 = Color3.fromRGB(0,60,140)
                    copyCustomFullBtn.Text = "Copy Custom Waypoints"
                end
            end)
        end
    end)

    local fullResetBtn=Instance.new("TextButton",expandFrame)
    fullResetBtn.Size=UDim2.new(1,0,0,18); fullResetBtn.BackgroundColor3=Color3.fromRGB(0,80,200); fullResetBtn.BorderSizePixel=0
    fullResetBtn.Text="Reset Full Defaults"; fullResetBtn.TextColor3=Color3.new(1,1,1)
    fullResetBtn.Font=Enum.Font.GothamBold; fullResetBtn.TextSize=7; fullResetBtn.TextScaled=false; fullResetBtn.ZIndex=22; fullResetBtn.LayoutOrder=6
    Instance.new("UICorner",fullResetBtn).CornerRadius=UDim.new(0,3)
    fullResetBtn.MouseButton1Click:Connect(function()
