-- [MODIFIED] Auto Left with reAutoPlay support
local function startAutoLeft()
    if _G._alConn then _G._alConn:Disconnect() end
    alPhase = 1
    local waypoints = getActiveLeftWaypoints()
    local isFull = leftPlayType == "full"
    local waitingCD = false
    local reAutoCheckDone = false
    
    _G._alConn = RunService.Heartbeat:Connect(function()
        if not auto1 then return end
        if waitingCD then return end
        local c = lp.Character; if not c then return end
        local root = c:FindFirstChild("HumanoidRootPart"); if not root then return end
        local hum2 = c:FindFirstChildOfClass("Humanoid"); if not hum2 then return end
        local target = waypoints[alPhase]
        if not target then
            -- [NEW] ReAutoPlay check - if finished all waypoints and reAutoPlay is on
            if reAutoPlayEnabled and isFull then
                if not reAutoCheckDone then
                    reAutoCheckDone = true
                    if not isAtCarrySpeedNonAutoPlay() then
                        -- Failed to be at carry speed, reauto
                        alPhase = 1
                        reAutoCheckDone = false
                        lastArmedSide = "left"
                        task.delay(reAutoPlayDelay, function()
                            if auto1 and reAutoCheckDone then
                                reAutoCheckDone = false
                            end
                        end)
                        return
                    end
                end
            end
            finishAutoLeft()
            return
        end
        local d = target - root.Position
        local mv = Vector3.new(d.X, 0, d.Z)
        if mv.Magnitude < 1 then
            hum2:Move(Vector3.zero, false)
            root.Velocity = Vector3.zero
            
            -- [MODIFIED] ReAutoPlay detection after 2nd waypoint
            if reAutoPlayEnabled and isFull and alPhase >= 2 then
                if not isAtCarrySpeedNonAutoPlay() then
                    -- Not at carry speed, reset to beginning
                    alPhase = 1
                    lastArmedSide = "left"
                    task.wait(reAutoPlayDelay)
                    return
                end
            end
            
            if isFull and alPhase == FULL_STEAL_THRESHOLD and autoPlayCD > 0 then
                alPhase = alPhase + 1
                waitingCD = true
                task.delay(autoPlayCD, function() waitingCD = false end)
            else
                alPhase = alPhase + 1
            end
            if autoTpDownWhenCarryingEnabled and isFull and alPhase == 3 then
                if not autoTpDownEnabled then
                    autoTpDownEnabled = true
                    uiStates["Auto Tp Down"] = true
                    if sideToggles["Auto Tp Down"] then sideToggles["Auto Tp Down"](true) end
                    applyAutoGoUp()
                end
            end
            if autoTpDownWhenCarryingEnabled and isFull and alPhase > 3 then
                if autoTpDownEnabled then
                    autoTpDownEnabled = false
                    uiStates["Auto Tp Down"] = false
                    if sideToggles["Auto Tp Down"] then sideToggles["Auto Tp Down"](false) end
                    applyAutoGoUp()
                end
            end
            if alPhase > #waypoints then finishAutoLeft(); return end
            return
        end
        local spd
        if isFull and alPhase > FULL_STEAL_THRESHOLD then spd = getSpeedVolta()
        else spd = getSpeedIda() end
        local dir = mv.Unit
        hum2:Move(dir, false)
        root.Velocity = Vector3.new(dir.X * spd, root.Velocity.Y, dir.Z * spd)
    end)
end

