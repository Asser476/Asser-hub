        else
            copyCustomSemiBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
            copyCustomSemiBtn.Text = "make sure to set first"
            task.delay(2, function()
                if copyCustomSemiBtn and copyCustomSemiBtn.Parent then
                    copyCustomSemiBtn.BackgroundColor3 = Color3.fromRGB(0,60,140)
                    copyCustomSemiBtn.Text = "Copy Custom Waypoints"
