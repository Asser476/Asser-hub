local function execSteal(prompt)
    local data = stealCache[prompt]; if not data or not data.ready then return false end
    data.ready = false; isStealing = true
    if grabBarStroke then grabBarStroke.Color = Color3.fromRGB(0, 150, 255) end
    local startTime = tick()
    task.spawn(function()
        for i = 1, #data.holdCallbacks do task.spawn(data.holdCallbacks[i]) end
        local elapsed = 0
        while elapsed < STEAL_DURATION do
            local prog = math.clamp((tick()-startTime)/STEAL_DURATION, 0, 1)
            if grabBarFill    then grabBarFill.Size = UDim2.fromScale(prog, 1) end
            if grabBarPercent then grabBarPercent.Text = math.floor(prog*100).."%" end
            elapsed = elapsed + task.wait()
        end
        for i = 1, #data.triggerCallbacks do task.spawn(data.triggerCallbacks[i]) end
        task.wait(0.01); resetStealBar(); task.wait(0.01); data.ready = true; isStealing = false
    end)
    return true
