local function applySpeedToHumanoid(hum, spd)
    if not hum then return end
    pcall(function() hum.WalkSpeed = spd end)
end

local function startSpeedBoost()
    if speedBoostConn then speedBoostConn:Disconnect() end
    speedBoostConn = RunService.RenderStepped:Connect(function()
        if not speedBoostEnabled then return end
        if speedBypassEnabled then return end
        if batAimbotEnabled then return end
        if medusaAimbotEnabled then return end
        if not sbCharacter or not sbHrp or not sbHum then return end
        local md = sbHum.MoveDirection
        local isCarry = sbHum.WalkSpeed < CARRY_SPEED_THRESHOLD
        local spd
        if lagModeActive then
            spd = isCarry and LAG_SPEED_VOLTA or LAG_SPEED_IDA
        else
            spd = isCarry and NORMAL_SPEED_VOLTA or NORMAL_SPEED_IDA
        end
        if not isCarry then applySpeedToHumanoid(sbHum, spd) end
        if md.Magnitude > 0 then
            lastMoveDir = md
            sbHrp.Velocity = Vector3.new(md.X * spd, sbHrp.Velocity.Y, md.Z * spd)
        else
            local anyHeld = false
            for key in pairs(MOVE_KEYS) do
                if UIS:IsKeyDown(key) then anyHeld = true; break end
            end
            if anyHeld and lastMoveDir.Magnitude > 0 then
                sbHrp.Velocity = Vector3.new(lastMoveDir.X * spd, sbHrp.Velocity.Y, lastMoveDir.Z * spd)
            end
        end
    end)
end

local function stopSpeedBoost()
    if speedBoostConn then speedBoostConn:Disconnect(); speedBoostConn = nil end
end

startSpeedBoost()

