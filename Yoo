local xrayEnabled = false
local xrayOriginalCache = {}

local function findDecorationParts()
    local parts = {}
    local plots = workspace:FindFirstChild("Plots")
    if plots then
        local plotChildren = plots:GetChildren()
        for i = 1, #plotChildren do
            local model = plotChildren[i]
            if model:IsA("Model") then
                local dec = model:FindFirstChild("Decorations")
                if dec and dec:IsA("Folder") then
                    local desc = dec:GetDescendants()
                    for j = 1, #desc do
                        local p = desc[j]
                        if p:IsA("BasePart") or p:IsA("MeshPart") or p:IsA("UnionOperation") then
                            table.insert(parts, p)
                        end
                    end
                end
            end
        end
    end
    return parts
end

local function enableXray()
    xrayEnabled = true
    local parts = findDecorationParts()
    for i = 1, #parts do
        local part = parts[i]
        if not xrayOriginalCache[part] then
            xrayOriginalCache[part] = part.Transparency
        end
        part.Transparency = 0.5
    end
end

local function disableXray()
    xrayEnabled = false
    for part, orig in pairs(xrayOriginalCache) do
        if part and part.Parent then
            part.Transparency = orig
        end
    end
    xrayOriginalCache = {}
end

