    end)

    local expanded=false
    local BTN_H=20; local BTN_GAP2=2; local FULL_COUNT=8; local SEMI_COUNT=5
    local function getTargetH() return isSemiMode() and SEMI_COUNT*BTN_H+(SEMI_COUNT-1)*BTN_GAP2 or FULL_COUNT*BTN_H+(FULL_COUNT-1)*BTN_GAP2 end
    local function showFull(v) for i=1,#fullBtns do fullBtns[i].Visible=v end; fullResetBtn.Visible=v; copyDefaultFullBtn.Visible=v; copyCustomFullBtn.Visible=v end
    local function showSemi(v) for i=1,#semiBtns do semiBtns[i].Visible=v end; semiResetBtn.Visible=v; copyDefaultSemiBtn.Visible=v; copyCustomSemiBtn.Visible=v end
    local function applyModeVis() if isSemiMode() then showFull(false); showSemi(true) else showFull(true); showSemi(false) end end
    local function doOpen() expanded=true; expandBtn.Text="▲"; applyModeVis(); TweenService:Create(expandFrame,TweenInfo.new(0.2,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{Size=UDim2.new(1,0,0,getTargetH())}):Play() end
    local function doClose() expanded=false; expandBtn.Text="▼"; TweenService:Create(expandFrame,TweenInfo.new(0.2,Enum.EasingStyle.Quad,Enum.EasingDirection.In),{Size=UDim2.new(1,0,0,0)}):Play() end
    local function onModeSwitch() applyModeVis(); if expanded then TweenService:Create(expandFrame,TweenInfo.new(0.2,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{Size=UDim2.new(1,0,0,getTargetH())}):Play() end end
    showFull(false); showSemi(false)
    expandBtn.MouseButton1Click:Connect(function() if expanded then doClose() else doOpen() end end)
    if sideShort=="left" then collapseLeftEditor=function() onModeSwitch() end else collapseRightEditor=function() onModeSwitch() end end
    return {onPlayTypeChange=function() onModeSwitch() end}
end

