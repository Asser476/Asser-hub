local function monitorCountdown(snd)
    if snd.Name ~= "Countdown" or not snd:IsA("Sound") then return end
    countdownActive = true
    local triggered, conn = false, nil
    conn = RunService.Heartbeat:Connect(function()
        if not snd or not snd.Parent or not snd.Playing then
            countdownActive = false
            G_armedSide = nil
            if setAutoLeftIndicatorColor  then setAutoLeftIndicatorColor("grey")  end
            if setAutoRightIndicatorColor then setAutoRightIndicatorColor("grey") end
            if conn then conn:Disconnect(); conn = nil end
            return
        end
        local ct = snd.TimePosition

        if auto1 and not triggered then
            auto1 = false
            if _G._alConn then _G._alConn:Disconnect(); _G._alConn = nil end
            alPhase = 1
            if setAutoLeftIndicatorColor then setAutoLeftIndicatorColor("yellow") end
            G_armedSide = "left"
        end
        if auto2 and not triggered then
            auto2 = false
            if _G._arConn then _G._arConn:Disconnect(); _G._arConn = nil end
            arPhase = 1
            if setAutoRightIndicatorColor then setAutoRightIndicatorColor("yellow") end
            G_armedSide = "right"
        end

        if ct >= COUNTDOWN_TARGET and not triggered then
            triggered = true
            if conn then conn:Disconnect(); conn = nil end
            countdownActive = false
            local armed = G_armedSide
            G_armedSide = nil
            if armed == "left" then runAutoLeft()
            elseif armed == "right" then runAutoRight() end
        end
        if ct > COUNTDOWN_TARGET + 2 then
            countdownActive = false
            if conn then conn:Disconnect(); conn = nil end
        end
    end)
end

