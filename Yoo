local function loadConfig()
    if not (isfile and isfile(configFile)) then return end
    local ok,data=pcall(function() return HttpService:JSONDecode(readfile(configFile)) end)
    if not ok or type(data)~="table" then return end
    local manualKeys={"ButtonPositions","SquarePanelPosition","NormalSpeedIda","NormalSpeedVolta","NormalFloatSpeed","NormalMedusaSpeed","LagSpeedIda","LagSpeedVolta","LagFloatSpeed","LagMedusaSpeed","BypassSpeedIda","BypassSpeedVolta","BypassFloatSpeed","BypassMedusaSpeed","BypassLagAmount","StealRadius","StealDuration","AutoPlayCD","AutoTpYLimit","SpeedBoost","FOV","FOVEnabled","LagMode","LagModeOnEnabled","MedusaRange","asserFloating","Auto Tp Down","LeftPlayType","RightPlayType","AutoSave","AutoLagOnLagger","ShowMySpeed","ShowOthersSpeed","LeftCustomWaypoints","RightCustomWaypoints","LeftCustomSemiWaypoints","RightCustomSemiWaypoints","AutoGoUp","AutoAfterDropEnabled","AutoAfterDropDelay","AutoAfterDropChoice","AntiBat","SlowFall","XrayEnabled","SquareButtonMode","AutoTpWhenCarrying","ReAutoPlayEnabled","ReAutoPlayDelay","MobileButtonsDraggable"}
    local skipSet={}; for i=1,#manualKeys do skipSet[manualKeys[i]]=true end
    for k,v in pairs(data) do
        if not skipSet[k] and not k:find("^KB_") then
            uiStates[k]=v
            if uiCallbacks[k] then uiCallbacks[k](v) end
            if toggles[k] then toggles[k].update(v) end
            if sideToggles[k] then sideToggles[k](v) end
        end
    end
    if data["NormalSpeedIda"]    then NORMAL_SPEED_IDA=data["NormalSpeedIda"];       speedGoingBox.Text=tostring(NORMAL_SPEED_IDA)    end
    if data["NormalSpeedVolta"]  then NORMAL_SPEED_VOLTA=data["NormalSpeedVolta"];   speedVoltaBox.Text=tostring(NORMAL_SPEED_VOLTA)  end
    if data["NormalFloatSpeed"]  then NORMAL_FLOAT_SPEED=data["NormalFloatSpeed"];   lockInSpeedBox.Text=tostring(NORMAL_FLOAT_SPEED)  end
    if data["NormalMedusaSpeed"] then NORMAL_MEDUSA_SPEED=data["NormalMedusaSpeed"]; medusaAimSpeedBox.Text=tostring(NORMAL_MEDUSA_SPEED) end
    if data["LagSpeedIda"]       then LAG_SPEED_IDA=data["LagSpeedIda"];             lagSpeedGoingBox.Text=tostring(LAG_SPEED_IDA)    end
    if data["LagSpeedVolta"]     then LAG_SPEED_VOLTA=data["LagSpeedVolta"];         lagSpeedVoltaBox.Text=tostring(LAG_SPEED_VOLTA)  end
    if data["LagFloatSpeed"]     then LAG_FLOAT_SPEED=data["LagFloatSpeed"];         lagLockInSpeedBox.Text=tostring(LAG_FLOAT_SPEED) end
    if data["LagMedusaSpeed"]    then LAG_MEDUSA_SPEED=data["LagMedusaSpeed"];       lagMedusaAimSpeedBox.Text=tostring(LAG_MEDUSA_SPEED) end
    if data["BypassSpeedIda"]    then BYPASS_SPEED_IDA=data["BypassSpeedIda"];       bypassGoingBox.Text=tostring(BYPASS_SPEED_IDA)  end
    if data["BypassSpeedVolta"]  then BYPASS_SPEED_VOLTA=data["BypassSpeedVolta"];   bypassVoltaBox.Text=tostring(BYPASS_SPEED_VOLTA) end
    if data["BypassFloatSpeed"]  then BYPASS_FLOAT_SPEED=data["BypassFloatSpeed"];   bypassAimbotBox.Text=tostring(BYPASS_FLOAT_SPEED) end
    if data["BypassMedusaSpeed"] then BYPASS_MEDUSA_SPEED=data["BypassMedusaSpeed"]; bypassMedusaAimBox.Text=tostring(BYPASS_MEDUSA_SPEED) end
    if data["StealRadius"]   then STEAL_R=data["StealRadius"]; radBox.Text=tostring(STEAL_R) end
    if data["StealDuration"] then STEAL_DURATION=math.max(data["StealDuration"],1.3); grabSpdBox.Text=tostring(STEAL_DURATION) end
    if data["AutoPlayCD"]    then autoPlayCD=math.clamp(data["AutoPlayCD"] or 0,0,3); cdBox.Text=tostring(autoPlayCD) end
    if data["AutoTpYLimit"]  then autoTpYLimit=data["AutoTpYLimit"]; autoTpYBox.Text=tostring(autoTpYLimit) end
    if data["MedusaRange"]   then MEDUSA_RANGE=data["MedusaRange"]; rebuildMedusaCircle() end
    if data["BypassLagAmount"] then bypassLagAmount=data["BypassLagAmount"] end
    if data["FOV"] then currentFOV=data["FOV"]; if uiCallbacks["FOVSlider"] then uiCallbacks["FOVSlider"](currentFOV) end end
    if data["FOVEnabled"]      ~=nil then if uiCallbacks["FOVEnabled"]      then uiCallbacks["FOVEnabled"](data["FOVEnabled"])           end end
    if data["AutoSave"]        ~=nil then if uiCallbacks["AutoSave"]        then uiCallbacks["AutoSave"](data["AutoSave"])               end end
    if data["AutoLagOnLagger"] ~=nil then if uiCallbacks["AutoLagOnLagger"] then uiCallbacks["AutoLagOnLagger"](data["AutoLagOnLagger"]) end end
    if data["LagModeOnEnabled"]~=nil then lagModeOnEnabled=data["LagModeOnEnabled"] end
    if data["LagMode"]~=nil then lagModeActive=data["LagMode"]; uiStates["Lag Mode"]=lagModeActive; if toggles["Lag Mode"] then toggles["Lag Mode"].update(lagModeActive) end; if sideToggles["Lag Mode"] then sideToggles["Lag Mode"](lagModeActive) end end
    if data["SpeedBoost"]~=nil then speedBoostEnabled=data["SpeedBoost"]; uiStates["Speed Boost"]=speedBoostEnabled; if toggles["Speed Boost"] then toggles["Speed Boost"].update(speedBoostEnabled) end; if speedBoostEnabled then stopSpeedBoost(); task.wait(0.15); startSpeedBoost() else stopSpeedBoost() end end
    if data["asserFloating"]~=nil then asserFloating=data["asserFloating"]; uiStates["Float"]=asserFloating; if toggles["Float"] then toggles["Float"].update(asserFloating) end; if asserFloating then startNewFloat() end end
    if data["Auto Tp Down"]~=nil then setAutoTpVisual(data["Auto Tp Down"]) end
    if data["LeftPlayType"]  then leftPlayType=data["LeftPlayType"]   end
    if data["RightPlayType"] then rightPlayType=data["RightPlayType"] end
    refreshApTypeVisuals(); buildWaypointMarkers()
    if leftEditorVisuals  and leftEditorVisuals.onPlayTypeChange  then leftEditorVisuals.onPlayTypeChange()  end
    if rightEditorVisuals and rightEditorVisuals.onPlayTypeChange then rightEditorVisuals.onPlayTypeChange() end
    if data["LeftCustomWaypoints"]      and type(data["LeftCustomWaypoints"])=="table"      then leftCustomWaypoints=data["LeftCustomWaypoints"]           end
    if data["RightCustomWaypoints"]     and type(data["RightCustomWaypoints"])=="table"     then rightCustomWaypoints=data["RightCustomWaypoints"]         end
    if data["LeftCustomSemiWaypoints"]  and type(data["LeftCustomSemiWaypoints"])=="table"  then leftCustomSemiWaypoints=data["LeftCustomSemiWaypoints"]   end
    if data["RightCustomSemiWaypoints"] and type(data["RightCustomSemiWaypoints"])=="table" then rightCustomSemiWaypoints=data["RightCustomSemiWaypoints"] end
