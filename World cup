if floatAttachment2 then floatAttachment2:Destroy(); floatAttachment2 = nil end
local hrp = char and char:FindFirstChild("HumanoidRootPart"); if not hrp then return end
floatAttachment2 = Instance.new("Attachment")
floatAttachment2.Name = "ZAY_FloatAttachment2"; floatAttachment2.Parent = hrp
floatVectorForce2 = Instance.new("VectorForce")
floatVectorForce2.Name = "ZAY_FloatForce2"
floatVectorForce2.Attachment0 = floatAttachment2
floatVectorForce2.ApplyAtCenterOfMass = true
floatVectorForce2.RelativeTo = Enum.ActuatorRelativeTo.World
floatVectorForce2.Force = Vector3.new(0,0,0)
floatVectorForce2.Parent = hrp
end

local function startNewFloat()
if Connections_float.main then return end
local char = lp.Character; if not char then return end
setupFloatObjects2(char)
floatMassCache2 = getCharMassFloat(char)
floatLastMassTime2 = tick()
floatJumping2 = false
if floatInfJumpConn2 then floatInfJumpConn2:Disconnect() end
floatInfJumpConn2 = UIS.JumpRequest:Connect(function()
if asserFloating then floatJumping2 = true end
end)
Connections_float.main = RunService.Heartbeat:Connect(function()
if not asserFloating then return end
pcall(function()
local c = lp.Character; if not c then return end
local hrp = c:FindFirstChild("HumanoidRootPart"); if not hrp then return end
if not floatVectorForce2 or not floatVectorForce2.Parent then setupFloatObjects2(c) end
local now = tick()
if now - floatLastMassTime2 > FLOAT_MASS_INTERVAL2 then
floatMassCache2 = getCharMassFloat(c); floatLastMassTime2 = now
end
local velY = hrp.Velocity.Y
local rp = RaycastParams.new()
rp.FilterDescendantsInstances = {c}
rp.FilterType = Enum.RaycastFilterType.Exclude
local ray = workspace:Raycast(hrp.Position, Vector3.new(0,-500,0), rp)
local groundY = ray and ray.Position.Y or (hrp.Position.Y - floatHeight)
local targetY = groundY + floatHeight
local diff = targetY - hrp.Position.Y
if floatJumping2 then
if velY > 0 then floatVectorForce2.Force = Vector3.new(0,0,0); return
else
if hrp.Position.Y > targetY + 0.3 then floatVectorForce2.Force = Vector3.new(0,0,0); return
else floatJumping2 = false; hrp.Velocity = Vector3.new(hrp.Velocity.X, 0, hrp.Velocity.Z) end
end
end
local gravComp = floatMassCache2 * workspace.Gravity
if math.abs(diff) < FLOAT_DEADZONE2 and math.abs(velY) < 0.3 then
floatVectorForce2.Force = Vector3.new(0, gravComp, 0); return
end
local pdForce = floatMassCache2 * (FLOAT_KP2 * diff - FLOAT_KD2 * velY)
floatVectorForce2.Force = Vector3.new(0, gravComp + pdForce, 0)
if hrp.Position.Y < targetY and velY < 0 then
hrp.Velocity = Vector3.new(hrp.Velocity.X, 0, hrp.Velocity.Z)
end
end)
end)
end

