local AntiRagdollEnabled=false; local ragConns={}
local function isKnockbackState(hum)
    local s=hum:GetState()
    return s==Enum.HumanoidStateType.Physics or s==Enum.HumanoidStateType.Ragdoll or s==Enum.HumanoidStateType.FallingDown or s==Enum.HumanoidStateType.GettingUp
end
local function enableControls()
    pcall(function()
        local module=lp:WaitForChild("PlayerScripts"):WaitForChild("PlayerModule")
        require(module):GetControls():Enable()
