local function makeToggleBtn(txt, callback, orderVal)
    uiCallbacks[txt]=callback; uiStates[txt]=false
    local frame=Instance.new("Frame",scroll)
    frame.Size=UDim2.new(1,-4,0,34); frame.BackgroundColor3=Color3.fromRGB(0,35,95)
    frame.BorderSizePixel=0; frame.LayoutOrder=orderVal or 99; frame.ZIndex=10
    Instance.new("UICorner",frame).CornerRadius=UDim.new(0,7)
    local lbl=Instance.new("TextLabel",frame)
    lbl.Size=UDim2.new(1,-44,1,0); lbl.Position=UDim2.new(0,8,0,0); lbl.Text=txt
    lbl.BackgroundTransparency=1; lbl.TextColor3=Color3.fromRGB(255,255,255)
    lbl.Font=Enum.Font.GothamMedium; lbl.TextSize=9; lbl.TextXAlignment=Enum.TextXAlignment.Left; lbl.ZIndex=11
    local toggle=Instance.new("TextButton",frame)
    toggle.Size=UDim2.new(0,30,0,18); toggle.Position=UDim2.new(1,-36,0.5,-9)
    toggle.BackgroundColor3=Color3.fromRGB(0,15,50); toggle.Text=""; toggle.ZIndex=11
    Instance.new("UICorner",toggle).CornerRadius=UDim.new(1,0)
    local circle=Instance.new("Frame",toggle)
    circle.Size=UDim2.new(0,12,0,12); circle.Position=UDim2.new(0,3,0,3)
    circle.BackgroundColor3=Color3.fromRGB(255,255,255); circle.ZIndex=12
    Instance.new("UICorner",circle).CornerRadius=UDim.new(1,0)
    local function updateVisual(active)
        TweenService:Create(toggle,TweenInfo.new(0.2),{BackgroundColor3=active and Color3.fromRGB(0,120,255) or Color3.fromRGB(0,15,50)}):Play()
        TweenService:Create(circle,TweenInfo.new(0.2),{Position=active and UDim2.new(1,-15,0,3) or UDim2.new(0,3,0,3)}):Play()
    end
    toggle.MouseButton1Click:Connect(function()
        uiStates[txt]=not uiStates[txt]; callback(uiStates[txt]); updateVisual(uiStates[txt])
        if sideToggles[txt] then sideToggles[txt](uiStates[txt]) end
    end)
    return {frame=frame, update=updateVisual}
end

local function makeSpeedRow(labelTxt, defaultVal, maxAllowed, orderVal, callback)
    local frame=Instance.new("Frame",scroll)
    frame.Size=UDim2.new(1,-4,0,34); frame.BackgroundColor3=Color3.fromRGB(0,35,95)
    frame.BorderSizePixel=0; frame.LayoutOrder=orderVal; frame.ZIndex=10
    Instance.new("UICorner",frame).CornerRadius=UDim.new(0,7)
    local lbl=Instance.new("TextLabel",frame)
    lbl.Size=UDim2.new(1,-70,1,0); lbl.Position=UDim2.new(0,8,0,0); lbl.Text=labelTxt
    lbl.BackgroundTransparency=1; lbl.TextColor3=Color3.new(1,1,1)
    lbl.Font=Enum.Font.GothamMedium; lbl.TextSize=9; lbl.TextXAlignment=Enum.TextXAlignment.Left; lbl.ZIndex=11
    local box=Instance.new("TextBox",frame)
    box.Size=UDim2.new(0,48,0,22); box.Position=UDim2.new(1,-54,0.5,-11)
    box.BackgroundColor3=Color3.fromRGB(0,15,50); box.Text=tostring(defaultVal)
    box.TextColor3=Color3.new(1,1,1); box.Font=Enum.Font.GothamBold; box.TextSize=11; box.ZIndex=11
    Instance.new("UICorner",box).CornerRadius=UDim.new(0,5)
    Instance.new("UIStroke",box).Color=Color3.fromRGB(0,188,255)
    local last=defaultVal
    box.FocusLost:Connect(function()
        local raw=box.Text:gsub("%s+",""); local num=tonumber(raw)
        if not raw or raw=="" or not num or num<=0 then box.Text=tostring(last); callback(last); return end
        if num>maxAllowed then num=maxAllowed end
        last=num; box.Text=tostring(num); callback(num)
    end)
end

